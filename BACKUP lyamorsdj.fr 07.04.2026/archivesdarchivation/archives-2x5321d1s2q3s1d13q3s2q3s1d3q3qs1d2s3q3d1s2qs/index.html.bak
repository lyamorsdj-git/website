<!DOCTYPE html>

<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <title>Lyamors DJ — Association musicale, événements & projets locaux</title>
  <meta name="description" content="Lyamors DJ est une association musicale engagée dans l'accompagnement d'événements, de projets locaux et d'initiatives collectives avec sérieux, accessibilité et professionnalisme.">
  <meta name="keywords" content="Lyamors DJ, association musicale, association musique, événement musical, projets musicaux, animation musicale, association événementielle, initiatives locales, accompagnement événementiel, musique pour tous, association culturelle, Bayonne, Pays Basque">
  <meta name="author" content="Lyamors DJ">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#1d56d8">
  <meta name="format-detection" content="telephone=yes, email=yes, address=yes">
  <meta name="color-scheme" content="light dark">

  <link rel="canonical" href="https://www.lyamorsdj.fr/">

  <meta property="og:locale" content="fr_FR">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Lyamors DJ">
  <meta property="og:title" content="Lyamors DJ — Association musicale, événements & projets locaux">
  <meta property="og:description" content="Une association musicale engagée pour accompagner événements, projets et initiatives locales avec une approche sérieuse, humaine et professionnelle.">
  <meta property="og:url" content="https://www.lyamorsdj.fr/">
  <meta property="og:image" content="https://www.lyamorsdj.fr/favicon.png">
  <meta property="og:image:alt" content="Logo de l'association Lyamors DJ">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Lyamors DJ — Association musicale, événements & projets locaux">
  <meta name="twitter:description" content="Association musicale engagée dans l'accompagnement d'événements, de projets et d'initiatives locales.">
  <meta name="twitter:image" content="https://www.lyamorsdj.fr/favicon.png">

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Lyamors DJ",
    "url": "https://www.lyamorsdj.fr/",
    "logo": "https://www.lyamorsdj.fr/favicon.png",
    "email": "contact@lyamorsdj.fr",
    "telephone": "+33564116245",
    "description": "Association musicale engagée dans l'accompagnement d'événements, de projets locaux et d'initiatives collectives.",
    "sameAs": [
      "https://www.lyamorsdj.fr/"
    ]
  }
  </script>

  <style>
    :root {
      --blue:       #1d56d8;
      --blue-dark:  #1540b0;
      --blue-light: #e8effd;
      --blue-mid:   #c5d7fa;
      --text:       #0f1923;
      --text-2:     #3d4d60;
      --text-3:     #6b7a8f;
      --border:     #dde3eb;
      --bg:         #ffffff;
      --bg-2:       #f5f7fa;
      --green:      #12a05c;
      --green-bg:   #e6f7ef;
      --shadow-sm:  0 1px 4px rgba(15,25,35,.07);
      --shadow-md:  0 4px 20px rgba(15,25,35,.09);
      --r: 12px;
      --max: 1160px;
      --font: 'Plus Jakarta Sans', sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --blue:       #6b9cff;
        --blue-dark:  #3e73df;
        --blue-light: #162338;
        --blue-mid:   #29466d;
        --text:       #eef4ff;
        --text-2:     #c8d4e8;
        --text-3:     #93a5bf;
        --border:     #243247;
        --bg:         #0b1220;
        --bg-2:       #101a2b;
        --green:      #49d18e;
        --green-bg:   #10271d;
        --shadow-sm:  0 1px 4px rgba(0,0,0,.28);
        --shadow-md:  0 8px 28px rgba(0,0,0,.35);
      }
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    img { display: block; max-width: 100%; }
    a { color: var(--blue); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .wrap { width: min(calc(100% - 32px), var(--max)); margin: 0 auto; }

    .topbar {
  background: #b91c1c;
  color: rgba(255,255,255,.92);
  font-size: .82rem;
  font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,.14);
}

.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 48px;
  gap: 12px;
  flex-wrap: wrap;
  padding: 8px 0;
}

.topbar-items {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  align-items: center;
}

.topbar-item {
  display: flex;
  align-items: center;
  gap: 8px;
}

.topbar-warning {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background: rgba(255,255,255,.10);
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 10px;
  color: #fff;
  font-weight: 600;
}

.topbar-warning svg {
  flex-shrink: 0;
}

.topbar a {
  color: #fff;
  font-weight: 700;
}

.topbar a:hover {
  text-decoration: underline;
}

    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: color-mix(in srgb, var(--bg) 92%, transparent);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
    }

    .nav-wrap { display: flex; align-items: center; justify-content: space-between; min-height: 68px; gap: 16px; }
    .brand { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }

    .brand-logo {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--bg-2);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
      position: relative;
    }

    .brand-logo img,
    .footer-logo img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 5px;
      filter: none !important;
      mix-blend-mode: normal;
    }

    .brand-logo .lfb { font-weight: 800; font-size: 1.1rem; color: var(--blue); }
    .brand-name strong { display: block; font-size: .97rem; font-weight: 700; color: var(--text); line-height: 1.2; }
    .brand-name span { font-size: .75rem; color: var(--text-3); font-weight: 500; }
    .nav-links { display: flex; align-items: center; gap: 2px; }
    .nav-links a { font-size: .9rem; font-weight: 600; color: var(--text-2); padding: 8px 14px; border-radius: 8px; transition: color .15s, background .15s; }
    .nav-links a:hover { color: var(--blue); background: var(--blue-light); text-decoration: none; }
    .btn { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font); font-weight: 700; font-size: .88rem; border-radius: var(--r); padding: 10px 20px; cursor: pointer; transition: all .18s; border: none; white-space: nowrap; text-decoration: none !important; }
    .btn-primary { background: var(--blue); color: #fff; box-shadow: 0 2px 8px rgba(29,86,216,.3); }
    .btn-primary:hover { background: var(--blue-dark); box-shadow: 0 4px 16px rgba(29,86,216,.4); transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--blue); border: 2px solid var(--blue); }
    .btn-outline:hover { background: var(--blue-light); }
    .btn-white { background: #fff; color: var(--blue); box-shadow: 0 2px 12px rgba(0,0,0,.15); }
    .btn-white:hover { background: var(--blue-light); transform: translateY(-1px); }
    .hamburger { display: none; background: none; border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; cursor: pointer; flex-direction: column; gap: 4px; }
    .hamburger span { display: block; width: 20px; height: 2px; background: var(--text); border-radius: 2px; }
    .nav-mobile { display: none; flex-direction: column; padding: 12px 0 16px; border-top: 1px solid var(--border); gap: 2px; }
    .nav-mobile.open { display: flex; }
    .nav-mobile a { font-size: .95rem; font-weight: 600; color: var(--text-2); padding: 11px 16px; border-radius: 8px; transition: color .15s, background .15s; }
    .nav-mobile a:hover { color: var(--blue); background: var(--blue-light); text-decoration: none; }
    .nav-mobile .btn-primary { margin: 8px 0 0; justify-content: center; }

    .hero { background: linear-gradient(145deg, #0c2868 0%, #1d56d8 55%, #2b6be8 100%); color: #fff; padding: 80px 0 72px; position: relative; overflow: hidden; }
    .hero::after { content: ''; position: absolute; right: -100px; bottom: -120px; width: 500px; height: 500px; border-radius: 50%; background: rgba(255,255,255,.04); pointer-events: none; }
    .hero::before { content: ''; position: absolute; right: 180px; top: -80px; width: 300px; height: 300px; border-radius: 50%; background: rgba(255,255,255,.03); pointer-events: none; }
    .hero-inner { display: grid; grid-template-columns: 1fr 370px; gap: 56px; align-items: center; position: relative; z-index: 1; }
    .hero-label { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); border-radius: 999px; padding: 5px 14px 5px 9px; font-size: .8rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; margin-bottom: 20px; }
    .dot-pulse { width: 8px; height: 8px; border-radius: 50%; background: #5dddaa; box-shadow: 0 0 0 3px rgba(93,221,170,.25); animation: dpulse 2s infinite; }
    @keyframes dpulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .hero h1 { font-size: clamp(2rem, 4.5vw, 3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -.025em; margin-bottom: 18px; }
    .hero h1 span { opacity: .7; font-weight: 400; }
    .hero-desc { font-size: 1.05rem; line-height: 1.75; color: rgba(255,255,255,.82); font-weight: 300; max-width: 500px; margin-bottom: 32px; }
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
    .hero-trust { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    .hero-trust-item { display: flex; align-items: center; gap: 8px; font-size: .83rem; color: rgba(255,255,255,.75); font-weight: 500; }

    .hero-card { background: var(--bg); border-radius: 16px; padding: 28px; box-shadow: 0 20px 60px rgba(0,0,0,.18); color: var(--text); border: 1px solid var(--border); }
    .hc-title { font-size: .74rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-3); margin-bottom: 16px; }
    .hc-rows { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .hc-row { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 10px; background: var(--bg-2); border: 1px solid var(--border); transition: border-color .2s; text-decoration: none !important; color: var(--text); }
    .hc-row:hover { border-color: var(--blue-mid); }
    .hc-icon { width: 36px; height: 36px; border-radius: 8px; background: var(--blue-light); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--blue); }
    .hc-text strong { display: block; font-size: .88rem; font-weight: 700; color: var(--text); }
    .hc-text span { font-size: .75rem; color: var(--text-3); }
    .hc-divider { height: 1px; background: var(--border); margin: 16px 0; }
    .hc-tags { display: flex; flex-wrap: wrap; gap: 7px; }
    .hc-tag { padding: 4px 11px; background: var(--blue-light); color: var(--blue); border-radius: 999px; font-size: .76rem; font-weight: 600; }

    .trust-bar { background: var(--bg-2); border-bottom: 1px solid var(--border); padding: 18px 0; }
    .trust-inner { display: flex; align-items: center; justify-content: center; gap: 36px; flex-wrap: wrap; }
    .trust-item { display: flex; align-items: center; gap: 9px; font-size: .85rem; font-weight: 600; color: var(--text-2); }
    .trust-icon { width: 32px; height: 32px; border-radius: 8px; background: var(--blue-light); display: flex; align-items: center; justify-content: center; color: var(--blue); flex-shrink: 0; }

    .section { padding: 80px 0; }
    .section-alt { background: var(--bg-2); }
    .section-tag { display: inline-block; font-size: .74rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--blue); background: var(--blue-light); padding: 4px 12px; border-radius: 999px; margin-bottom: 12px; }
    h2.section-title { font-size: clamp(1.7rem, 3.2vw, 2.5rem); font-weight: 800; letter-spacing: -.025em; line-height: 1.15; color: var(--text); margin-bottom: 12px; }
    .section-sub { font-size: 1rem; color: var(--text-3); font-weight: 400; max-width: 540px; line-height: 1.75; }
    .section-head { margin-bottom: 48px; }
    .section-head.center { text-align: center; }
    .section-head.center .section-sub { margin: 0 auto; }

    .cards-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r); padding: 28px 26px; box-shadow: var(--shadow-sm); transition: box-shadow .2s, transform .2s, border-color .2s; }
    .card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); border-color: var(--blue-mid); }
    .card-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--blue-light); display: flex; align-items: center; justify-content: center; color: var(--blue); margin-bottom: 18px; }
    .card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; color: var(--text); }
    .card p { font-size: .9rem; color: var(--text-3); line-height: 1.7; }
    .card-link { display: inline-flex; align-items: center; gap: 5px; margin-top: 16px; font-size: .85rem; font-weight: 700; color: var(--blue); }
    .card-link:hover { text-decoration: underline; }

    .split-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
    .split-visual { background: linear-gradient(135deg, var(--blue-light), #dce8fd); border-radius: 16px; padding: 36px; border: 1px solid var(--blue-mid); position: relative; overflow: hidden; }
    .split-visual::before { content: ''; position: absolute; bottom: -30px; right: -30px; width: 150px; height: 150px; border-radius: 50%; background: rgba(29,86,216,.08); }
    .sv-big { font-size: 3rem; font-weight: 800; letter-spacing: -.04em; color: var(--blue); line-height: 1; margin-bottom: 4px; }
    .sv-sub { font-size: .78rem; font-weight: 600; color: var(--text-3); margin-bottom: 24px; text-transform: uppercase; letter-spacing: .06em; }
    .sv-rows { display: flex; flex-direction: column; }
    .sv-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(29,86,216,.12); font-size: .9rem; gap: 16px; }
    .sv-row:last-child { border-bottom: none; }
    .sv-row-k { color: var(--text-2); font-weight: 500; }
    .sv-row-v { font-weight: 700; color: var(--text); text-align: right; }
    .badge-g { display: inline-flex; align-items: center; gap: 5px; background: var(--green-bg); color: var(--green); font-size: .78rem; font-weight: 700; padding: 3px 10px; border-radius: 999px; }
    .badge-g::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--green); }
    .checklist { display: flex; flex-direction: column; gap: 14px; margin: 24px 0; }
    .check-item { display: flex; align-items: flex-start; gap: 14px; }
    .check-ico { width: 22px; height: 22px; border-radius: 50%; background: var(--blue-light); display: flex; align-items: center; justify-content: center; color: var(--blue); flex-shrink: 0; margin-top: 2px; }

    .stats-strip { background: linear-gradient(135deg, #0c2868, #1d56d8); color: #fff; padding: 56px 0; }
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    .stat-item { text-align: center; padding: 16px 24px; border-right: 1px solid rgba(255,255,255,.1); }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-size: 2.4rem; font-weight: 800; letter-spacing: -.04em; margin-bottom: 6px; line-height: 1; }
    .stat-label { font-size: .85rem; color: rgba(255,255,255,.7); }

    .projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .proj-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; box-shadow: var(--shadow-sm); transition: box-shadow .2s, transform .2s; }
    .proj-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
    .proj-top { padding: 24px; }
    .proj-num { font-size: .74rem; font-weight: 700; color: var(--blue); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px; }
    .proj-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; color: var(--text); }
    .proj-card p { font-size: .88rem; color: var(--text-3); line-height: 1.7; }
    .proj-foot { padding: 13px 24px; background: var(--bg-2); border-top: 1px solid var(--border); }
    .proj-tag { font-size: .76rem; font-weight: 700; color: var(--blue); background: var(--blue-light); padding: 3px 10px; border-radius: 999px; }

    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 36px; align-items: start; }
    .contact-info { display: flex; flex-direction: column; gap: 14px; }
    .contact-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r); padding: 22px; display: flex; gap: 16px; align-items: flex-start; box-shadow: var(--shadow-sm); transition: border-color .2s; }
    .contact-card:hover { border-color: var(--blue-mid); }
    .cc-icon { width: 44px; height: 44px; border-radius: 10px; background: var(--blue-light); display: flex; align-items: center; justify-content: center; color: var(--blue); flex-shrink: 0; }
    .cc-body h4 { font-size: .76rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--text-3); margin-bottom: 5px; }
    .cc-body p { font-size: .95rem; color: var(--text); font-weight: 500; }
    .contact-note { padding: 16px 20px; background: var(--blue-light); border-left: 3px solid var(--blue); border-radius: 0 10px 10px 0; font-size: .88rem; color: var(--text-2); line-height: 1.65; }

    .site-footer { background: #0c1929; color: #fff; padding: 60px 0 0; }
    .footer-grid { display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr; gap: 40px; padding-bottom: 48px; }
    .footer-brand { display: flex; align-items: center; gap: 11px; margin-bottom: 14px; }
    .footer-logo {
      width: 38px;
      height: 38px;
      border-radius: 9px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .footer-logo .lfb { font-weight: 800; font-size: .9rem; color: #fff; }
    .footer-brand strong { font-size: .95rem; font-weight: 700; }
    .footer-about { font-size: .87rem; color: rgba(255,255,255,.5); line-height: 1.7; font-weight: 300; margin-bottom: 18px; }
    .footer-col h4 { font-size: .74rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.38); margin-bottom: 14px; }
    .footer-links { display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: .88rem; color: rgba(255,255,255,.58); transition: color .15s; }
    .footer-links a:hover { color: #fff; text-decoration: none; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.08); padding: 20px 0; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .footer-bottom p { font-size: .8rem; color: rgba(255,255,255,.33); }
    .footer-bottom-links { display: flex; gap: 20px; }
    .footer-bottom-links a { font-size: .8rem; color: rgba(255,255,255,.38); }
    .footer-bottom-links a:hover { color: rgba(255,255,255,.65); text-decoration: none; }

    .reveal { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
    .reveal.in { opacity: 1; transform: none; }
    .rd1 { transition-delay: .1s; }
    .rd2 { transition-delay: .2s; }
    .rd3 { transition-delay: .3s; }

    @media (max-width: 1024px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-card { max-width: 460px; }
      .split-2 { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .cards-3, .projects-grid { grid-template-columns: 1fr 1fr; }
      .stats-grid { grid-template-columns: 1fr; }
      .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,.1); padding: 20px; }
      .stat-item:last-child { border-bottom: none; }
      .contact-grid { grid-template-columns: 1fr; }
      .nav-links, .nav-cta { display: none; }
      .hamburger { display: flex; }
      .section { padding: 56px 0; }
      .hero { padding: 56px 0 52px; }
      .trust-inner { gap: 20px; justify-content: flex-start; }
    }

    @media (max-width: 540px) {
      .cards-3, .projects-grid { grid-template-columns: 1fr; }
      .hero-actions { flex-direction: column; align-items: flex-start; }
      .footer-grid { grid-template-columns: 1fr; }
      .topbar-item:not(:first-child) { display: none; }
    }
  </style>
</head>
<body>

<div class="topbar">
<div class="wrap topbar-inner">
  <div class="topbar-items"> 
 <!--      <div class="topbar-warning"> -->
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true">
  <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
  <path d="M12 9v4"/>
</svg>
